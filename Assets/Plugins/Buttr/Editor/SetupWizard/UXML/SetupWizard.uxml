            <ui:VisualElement name="Setup__Repository" style="flex-grow: 1; margin-top: 10px; margin-right: 10px; margin-bottom: 10px; margin-left: 10px; background-color: rgb(56, 56, 54); border-top-left-radius: 5px; border-top-right-radius: 5px; border-bottom-right-radius: 5px; border-bottom-left-radius: 5px; width: 500px; height: 275px; position: absolute; padding-top: 10px; padding-right: 10px; padding-bottom: 10px; padding-left: 10px; left: 520px;">
                <ui:Toggle label=" SQLite &lt;size=10&gt;&lt;color=#888888FF&gt;Installs SQLite and package to manage it&lt;/color&gt;&lt;/size&gt;" name="SQLite__Toggle" style="flex-direction: row-reverse;" />
                <ui:Toggle label=" PlayerPrefs &lt;size=10&gt;&lt;color=#888888FF&gt;Installs package to manage player prefs persistence&lt;/color&gt;&lt;/size&gt;" name="PlayerPrefs__Toggle" style="flex-direction: row-reverse;" />
                <ui:Toggle label=" Custom &lt;size=10&gt;&lt;color=#888888FF&gt;Installs base package to extend and build custom data persistence&lt;/color&gt;&lt;/size&gt;" name="Custom__Toggle" style="flex-direction: row-reverse;" />
