                    <ui:VisualElement name="RootFolder__Separator" style="flex-grow: 0; height: 1px; color: rgb(136, 136, 136); background-color: rgb(136, 136, 136); margin-right: 0; margin-left: 0; margin-top: 0; margin-bottom: 0; width: 475px;" />
                    <ui:Toggle label="Add Main Scene to Build Settings" value="false" name="AddMainSceneToBuildSettings__Toggle" style="font-size: 12px; width: 450px; height: 50px;" />
                    <ui:VisualElement name="RootFolder__Separator" style="flex-grow: 0; height: 1px; color: rgb(136, 136, 136); background-color: rgb(136, 136, 136); margin-right: 0; margin-left: 0; margin-top: 0; margin-bottom: 0; width: 475px;" />
                    <ui:Toggle label="Open the Main scene after setup" value="false" name="OpenMainSceneAfterSetup__Toggle" style="font-size: 12px; width: 450px; height: 50px;" />
                    <ui:VisualElement name="RootFolder__Separator" style="flex-grow: 0; height: 1px; color: rgb(136, 136, 136); background-color: rgb(136, 136, 136); margin-right: 0; margin-left: 0; margin-top: 0; margin-bottom: 0; width: 475px;" />
                    <ui:Toggle label="Create Program.cs file in your Root folder" value="false" name="CreateProgramCS__Toggle" style="font-size: 12px; width: 450px; height: 50px;" />
                    <ui:VisualElement name="RootFolder__Separator" style="flex-grow: 0; height: 1px; color: rgb(136, 136, 136); background-color: rgb(136, 136, 136); margin-right: 0; margin-left: 0; margin-top: 0; margin-bottom: 0; width: 475px;" />
                    <ui:Toggle label="Create a Loader for the Program.cs file in your Root folder" value="false" name="CreateProgramLoader__Toggle" style="font-size: 12px; width: 450px; height: 50px;" />
                </ui:ScrollView>
