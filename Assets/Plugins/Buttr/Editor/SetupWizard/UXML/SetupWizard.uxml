                        <ui:TextField placeholder-text="_Project" style="flex-grow: 0; margin-right: 0; margin-left: 50px; font-size: 12px; width: 225px; height: 40px; min-width: 225px; min-height: 40px; max-height: 40px;" />
                    </ui:VisualElement>
